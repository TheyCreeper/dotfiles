# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias la='ls -la'
alias clear='clear && fastfetch'
alias clr="clear"
alias cma='chezmoi apply'
alias nedit='sudo micro /etc/nixos/configuration.nix'
alias napply='sudo nixos-rebuild switch --upgrade'
alias ngc='sudo nix-collect-garbage -d --delete-older-than 10d'
alias lff=$'lf -command \'set hidden true\'' 
alias fastfetch='fastfetch --logo-type small --logo arch'
alias e='exit'
alias apienv='cd ~/Documents/Dev/CarDB/CarDB_Api && source ~/Documents/Dev/CarDB/CarDB_Api/.venv/bin/activate'
alias appenv='cd ~/Documents/Dev/CarDB/CarDB_App && npm run dev'

fastfetch
PS1='\w > '

. "$HOME/.atuin/bin/env"

[[ -f ~/.bash-preexec.sh ]] && source ~/.bash-preexec.sh
eval "$(atuin init bash)"
